# ─── Test files ───────────────────────────────────────────────────────────────
# Jest (JS convention) – also covered by !**/__tests__ in package.json files
**/__tests__/
**/__mocks__/
**/__fixtures__/

# Android (Java/Kotlin convention — not caught by __tests__ pattern)
android/src/test/
android/src/androidTest/

# ─── Build artifacts ──────────────────────────────────────────────────────────
android/build/
android/.cxx/
android/app/build/
ios/build/
ios/DerivedData/
lib/commonjs/

# ─── Android Gradle wrapper (large binaries, regenerated by consuming project) ─
android/gradle/
android/gradlew
android/gradlew.bat
android/local.properties

# ─── iOS workspace / Pods (generated, not source) ─────────────────────────────
ios/*.xcworkspace
ios/*.xcodeproj
ios/Pods/

# ─── Dev / CI configuration ───────────────────────────────────────────────────
.github/
.trunk/
.cspell/
.yarn/
babel.config.js
bob.config.js
cspell.config.yaml
eslint.config.mjs
jest.config.js
tsconfig.json
tsconfig.build.json
turbo.json
.editorconfig
.eslintrc*
.prettierrc*
.nvmrc
.watchmanconfig
.gitattributes
.yarnrc.yml
yarn.lock

# ─── Example app ──────────────────────────────────────────────────────────────
example/

# ─── Docs (internal contributor docs, not consumer-facing API reference) ──────
docs/

# ─── Contributor docs ─────────────────────────────────────────────────────────
CONTRIBUTING.md
CODE_OF_CONDUCT.md
CLAUDE.md
